rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Session exchange logs: write-only from the client (children never read
    // back raw logs), read access reserved for authenticated researchers/parents.
    match /sessions/{sessionId}/exchanges/{exchangeId} {
      allow create: if true;
      allow read: if request.auth != null;
      allow update, delete: if false;
    }
  }
}
