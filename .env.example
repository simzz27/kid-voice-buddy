# URL of YOUR deployed Cloudflare Worker (from `wrangler deploy` output).
# This is safe to be public — it is NOT a secret, just an endpoint.
# The actual Gemini API key lives only in Cloudflare's secret store
# (set via `wrangler secret put GEMINI_API_KEY` inside the worker/ folder),
# never here and never in any file that gets committed.
VITE_WORKER_URL=https://curio-gemini-proxy.YOUR-SUBDOMAIN.workers.dev

# Firebase project config — from Firebase Console > Project Settings
# (optional — the app works without these, session logging just no-ops)
VITE_FIREBASE_API_KEY=your_firebase_api_key
VITE_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your-project-id
VITE_FIREBASE_STORAGE_BUCKET=your-project.appspot.com
VITE_FIREBASE_APP_ID=your_firebase_app_id
